# ─── Helix Blockchain node configuration ──────────────────────────────
# Copy to `.env` and adjust. NEVER commit the real `.env`.

# This validator node's identity
HELIX_NODE__NODE_ID=node-1
# Hex-encoded Ed25519 private seed (32 bytes / 64 hex chars).
# Generate one with: python -m helix_blockchain.tools.keygen
HELIX_NODE__PRIVATE_KEY_HEX=

# ─── FIWARE Orion / MongoDB (data source being monitored) ─────────────
HELIX_ORION__HOST=localhost
HELIX_ORION__PORT=27017
HELIX_ORION__USERNAME=helix
HELIX_ORION__PASSWORD=changeme
HELIX_ORION__DATABASE=orion
HELIX_ORION__TLS=false
# Seconds between integrity polls
HELIX_ORION__POLL_INTERVAL=5.0

# ─── Consensus / validator set ────────────────────────────────────────
# Comma-separated list of peer validators as id@host:port|pubkey_hex
# e.g. node-2@10.0.0.2:8000|<hex>,node-3@10.0.0.3:8000|<hex>
HELIX_CONSENSUS__PEERS=
# HTTP bind for this node's P2P + API server
HELIX_CONSENSUS__BIND_HOST=0.0.0.0
HELIX_CONSENSUS__BIND_PORT=8000
# Block production target interval (seconds)
HELIX_CONSENSUS__BLOCK_INTERVAL=5.0

# ─── Storage (blockchain persistence) ─────────────────────────────────
# SQLAlchemy URL. SQLite for dev, Postgres for prod.
HELIX_STORAGE__URL=sqlite:///data/helix_chain.db

# ─── Logging ──────────────────────────────────────────────────────────
HELIX_LOG_LEVEL=INFO
