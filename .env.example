# ─── Helix Blockchain node configuration ──────────────────────────────
# Copy to `.env` and adjust. NEVER commit the real `.env`.

# This validator node's identity
HELIX_NODE__NODE_ID=node-1
# Hex-encoded Ed25519 private seed (32 bytes / 64 hex chars).
# Generate one with: python -m helix_blockchain.tools.keygen
HELIX_NODE__PRIVATE_KEY_HEX=
# ...or load it from a mounted secret file (Docker/k8s/Vault-agent). Preferred
# in production so the key never lives in env/code. Takes precedence if set.
# HELIX_NODE__PRIVATE_KEY_FILE=/run/secrets/helix_private_key

# ─── FIWARE Orion / MongoDB (data source being monitored) ─────────────
HELIX_ORION__HOST=localhost
HELIX_ORION__PORT=27017
HELIX_ORION__USERNAME=helix
HELIX_ORION__PASSWORD=changeme
HELIX_ORION__DATABASE=orion
HELIX_ORION__TLS=false
# Seconds between integrity polls
HELIX_ORION__POLL_INTERVAL=5.0

# ─── Consensus / validator set ────────────────────────────────────────
# Comma-separated list of peer validators as id@host:port|pubkey_hex
# e.g. node-2@10.0.0.2:8000|<hex>,node-3@10.0.0.3:8000|<hex>
HELIX_CONSENSUS__PEERS=
# HTTP bind for this node's P2P + API server
HELIX_CONSENSUS__BIND_HOST=0.0.0.0
HELIX_CONSENSUS__BIND_PORT=8000
# Address peers should reach this node at (for auto peer discovery via /peers).
# Usually the routable host:port, e.g. node-1:8000 or 10.0.0.1:8000.
HELIX_CONSENSUS__ADVERTISE=
# Block production target interval (seconds)
HELIX_CONSENSUS__BLOCK_INTERVAL=5.0

# ─── Storage (blockchain persistence) ─────────────────────────────────
# SQLAlchemy URL. SQLite for dev, Postgres for prod.
HELIX_STORAGE__URL=sqlite:///data/helix_chain.db

# ─── Security ─────────────────────────────────────────────────────────
# Shared bearer token(s) authenticating peer-to-peer endpoints. Set the SAME
# value on every validator. Empty = disabled. Comma-separate to accept several
# during rotation (e.g. "newtoken,oldtoken"); the first is used for outbound.
HELIX_CLUSTER_TOKEN=
# ...or load token(s) from a mounted secret file (preferred in production).
# HELIX_CLUSTER_TOKEN_FILE=/run/secrets/helix_cluster_token

# Confidentiality: shared key (hex) turning stored value fingerprints into keyed
# commitments (HMAC) — blocks brute-force of low-entropy values by chain readers.
# Same value on EVERY validator. Empty = plain SHA-256 (no confidentiality).
HELIX_COMMIT_KEY_HEX=
# HELIX_COMMIT_KEY_FILE=/run/secrets/helix_commit_key
# Pseudonymize entity_id on-chain (LGPD). Trade-off: alerts show an opaque id.
HELIX_PSEUDONYMIZE_ENTITIES=false

# TLS / mutual TLS for the validator P2P layer. Generate dev certs with:
#   python -m helix_blockchain.tools.gen_certs ./certs node-1 node-2 node-3
HELIX_TLS__ENABLED=false
HELIX_TLS__CERT_FILE=./certs/node-1.crt
HELIX_TLS__KEY_FILE=./certs/node-1.key
HELIX_TLS__CA_FILE=./certs/ca.crt
HELIX_TLS__MUTUAL=false              # true = require client certs (mTLS)
# HELIX_TLS__CLIENT_CERT_FILE=        # defaults to CERT_FILE
# HELIX_TLS__CLIENT_KEY_FILE=         # defaults to KEY_FILE

# MongoDB TLS (the Orion broker database)
# HELIX_ORION__TLS=true
# HELIX_ORION__TLS_CA_FILE=./certs/mongo-ca.crt

# ─── Logging ──────────────────────────────────────────────────────────
HELIX_LOG_LEVEL=INFO
